# AI Glass System - 环境变量配置模板
# 智能盲人导航眼镜系统
#
# 使用方法：
# 1. 复制此文件为 .env: cp .env.example .env
# 2. 填写实际的配置值（特别是 API Key）
# 3. .env 文件不会被提交到 Git（已在 .gitignore 中）

# ==================== 必填配置 ====================

# DashScope API Key（阿里云灵积平台）
# 获取地址: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=sk-your-api-key-here

# ==================== 模型路径配置 ====================

# YOLO 模型文件路径（盲道检测）
BLIND_PATH_MODEL=model/yolo-seg.pt

# 障碍物检测模型路径
OBSTACLE_MODEL=model/yoloe-11l-seg.pt

# YOLO-E 模型路径（开放词汇检测）
YOLOE_MODEL_PATH=model/yoloe-11l-seg.pt

# 红绿灯检测模型路径
TRAFFIC_LIGHT_MODEL=model/trafficlight.pt

# 物品查找模型路径
SHOPPING_MODEL=model/shoppingbest5.pt

# 手部检测任务文件路径
HAND_TASK_PATH=model/hand_landmarker.task

# ==================== 功能开关 ====================

# 是否启用 TTS 语音播报
ENABLE_TTS=true

# TTS 播报间隔（秒）
TTS_INTERVAL_SEC=1.0

# 是否启用长期记忆
ENABLE_MEMORY=true

# 是否启用 Agent 对话
ENABLE_AGENT=true

# ==================== 性能配置 ====================

# 日志级别: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# YOLO 推理设备: cuda, cpu, mps
DEVICE=cuda

# YOLO 推理置信度阈值
CONFIDENCE_THRESHOLD=0.25

# ==================== 网络配置 ====================

# 服务端口
SERVER_PORT=8081

# UDP 监听地址（ESP32 IMU 数据）
UDP_HOST=0.0.0.0
UDP_PORT=12345

# ==================== 阿里云配置（可选）====================

# 阿里云 OSS（用于存储录音文件）
# OSS_ACCESS_KEY_ID=
# OSS_ACCESS_KEY_SECRET=
# OSS_ENDPOINT=
# OSS_BUCKET=

# ==================== 第三方服务配置（可选）====================

# Edge TTS 配置
EDGE_TTS_VOICE=zh-CN-XiaoxiaoNeural
EDGE_TTS_RATE=+0%

# ==================== 开发/调试配置 ====================

# 是否启用调试模式（仅开发环境）
DEBUG=false

# 是否启用 CORS（跨域请求）
ENABLE_CORS=false

# 允许的 CORS 源（逗号分隔）
CORS_ORIGINS=http://localhost:8081,http://localhost:3000

# ==================== Docker 部署配置 ====================

# 时区设置
TZ=Asia/Shanghai

# 工作目录
WORK_DIR=/app

# ==================== 监控配置（可选）====================

# 是否启用性能监控
ENABLE_MONITORING=false

# Prometheus 端口（如果启用）
# PROMETHEUS_PORT=9090
